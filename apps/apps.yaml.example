---
# HA Energy Forecast — AppDaemon configuration
#
# Copy this file to apps.yaml and fill in your own values.
# apps.yaml is gitignored because it contains API credentials.
#
# ── Required ──────────────────────────────────────────────────────────────────
#
#   energy_sensor     The entity_id of your cumulative grid-import energy
#                     sensor. Must be a kWh meter that counts upward over time
#                     (i.e. total_increasing). Example: sensor.grid_import_kwh
#
#   latitude          Your home latitude  (decimal degrees)
#   longitude         Your home longitude (decimal degrees)
#
# ── Optional ──────────────────────────────────────────────────────────────────
#
#   outdoor_temp_sensor   entity_id of an outdoor temperature sensor.
#                         When provided, it is blended with the SRG-SSR / Open-Meteo
#                         forecast for the first 6 hours to improve accuracy.
#
#   srg_client_id / srg_client_secret
#                         SRG-SSR API credentials for high-quality Swiss
#                         weather forecasts. Obtain from developer.srgssr.ch.
#                         If omitted, Open-Meteo is used automatically.
#                         The nearest weather station is resolved from your
#                         latitude/longitude — no postal code needed.
#
#   timezone          Timezone for all forecasts. Default: Europe/Zurich
#
# ─────────────────────────────────────────────────────────────────────────────

energy_forecast:
  module: energy_forecast.energy_forecast
  class: EnergyForecast

  # ── Required ────────────────────────────────────────────────────────────────
  energy_sensor: sensor.your_grid_import_sensor  # ← change this
  latitude: 47.0                                  # ← change this
  longitude: 8.0                                  # ← change this

  # ── SRG-SSR weather API (optional — falls back to Open-Meteo if absent) ────
  # srg_client_id: YOUR_CLIENT_ID
  # srg_client_secret: YOUR_CLIENT_SECRET

  # ── Optional ────────────────────────────────────────────────────────────────
  # outdoor_temp_sensor: sensor.outdoor_temperature
  timezone: Europe/Zurich  # ← change if you're outside Switzerland (IANA timezone name)

  # Optional: exponential sample weight half-life in days (default: 90).
  # Lower = recent data matters more. Set to 0 to disable weighting.
  weight_halflife_days: 90

  # Optional: two-letter Swiss canton code for cantonal holidays (e.g. ZH, BE, GE).
  # If omitted, only federal public holidays are used.
  # holiday_canton: ZH

  # Optional: adaptive retraining threshold (default: 2.0).
  # Triggers an early retrain when live MAE (day-ahead predictions vs actuals,
  # over the last 24+ matched hours) exceeds this multiple of the CV MAE.
  # Set higher to retrain less aggressively; 0 disables the feature.
  # adaptive_retrain_threshold: 2.0

  # Optional: anomaly detection threshold (default: 3.0).
  # binary_sensor.energy_forecast_unusual_consumption fires when the latest
  # actual consumption deviates more than this many std-deviations from the
  # model's day-ahead prediction. Requires ≥10 matched pairs (cold-start safe).
  # anomaly_sigma_threshold: 3.0

  # Optional: number of top SHAP features exposed as sensor attributes on
  # sensor.energy_forecast_today (default: 5). Set to 0 to disable.
  # shap_top_n: 5

  # Optional: cumulative kWh sub-sensors whose hourly consumption is tracked
  # as lag_24h / lag_168h features to improve forecast accuracy.
  # Must be total_increasing kWh meters (e.g. heat pump, dishwasher monitor).
  # Power (W/kW) sensors must first be integrated into a kWh template in HA.
  # sub_energy_sensors:
  #   - sensor.heat_pump_energy_kwh
  #   - sensor.dishwasher_energy_kwh

  # Optional: EV charging detection.
  # Hours where gross consumption exceeds ev_charging_threshold_kwh are treated
  # as EV charging sessions.  The charger load (ev_charger_kw) is subtracted
  # before training so household baseline accuracy is preserved.
  # ev_charging_threshold_kwh: 7    # default: 7 kWh/h
  # ev_charger_kw: 9                # default: 9 kW (e.g. 11 kW Type 2 at ~80% efficiency)

  # Optional: solar PV + battery target correction.
  # Corrects the training target from grid-import-only to true household
  # consumption:
  #   total_consumption = grid_import − grid_export
  #                       + solar_production
  #                       − battery_charge + battery_discharge
  #
  # All sensors must be CUMULATIVE kWh entities
  # (device_class: energy, state_class: total_increasing).
  # If your inverter only exposes instantaneous power (W/kW), create a
  # Riemann sum integration helper first (HA > Settings > Helpers).
  #
  # SolarEdge Modbus Multi (entity names are user-defined in the integration):
  # solar_production_sensor:  sensor.solaredge_ac_energy_kwh
  # grid_export_sensor:       sensor.solaredge_exported_energy_kwh  # required with solar
  # battery_charge_sensor:    sensor.solaredge_battery_charge_kwh   # may need Riemann sum
  # battery_discharge_sensor: sensor.solaredge_battery_discharge_kwh
  #
  # Enphase Envoy (native cumulative sensors — replace SERIAL with your gateway serial):
  # solar_production_sensor:  sensor.envoy_SERIAL_lifetime_energy_production
  # grid_export_sensor:       sensor.envoy_SERIAL_lifetime_net_energy_production
  # battery_charge_sensor:    sensor.envoy_SERIAL_lifetime_battery_energy_charged
  # battery_discharge_sensor: sensor.envoy_SERIAL_lifetime_battery_energy_discharged

  # Optional: entity that signals vacation / away mode.
  # When "on", the model learns lower consumption patterns from historical away periods
  # and predicts accordingly.
  # away_mode_entity: input_boolean.vacation_mode

  # Optional: entity holding the expected return datetime (input_datetime).
  # Used to project is_away=0 for hours after the return within the 48h forecast.
  # Requires away_mode_entity to be configured.
  # away_return_entity: input_datetime.vacation_return

  # ── MQTT Discovery (optional) ─────────────────────────────────────────────
  # Registers all sensors in the HA entity registry (enables area assignment).
  # Requires AppDaemon MQTT plugin in appdaemon.yaml + a running MQTT broker.
  # mqtt_discovery: false
  # mqtt_namespace: mqtt
  # mqtt_discovery_prefix: homeassistant

# ── One-off backfill (uncomment only when needed) ────────────────────────────
#energy_history_backfill:
#  module: energy_forecast.energy_history_backfill
#  class: EnergyHistoryBackfill
#  energy_sensor: sensor.your_grid_import_sensor
#  ha_db_path: /homeassistant/home-assistant_v2.db
